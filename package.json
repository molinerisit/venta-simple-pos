{
  "name": "venta-simple-hub",
  "version": "1.1.57",
  "description": "Sistema de gestión para negocios — ventas, stock, clientes y reportes con sincronización en la nube",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "release": "electron-builder --publish always",
    "test:phase2": "node tests/run-phase-2.js",
    "test:phase3": "node tests/run-phase-3.js",
    "test:phase4": "node tests/run-phase-4.js",
    "test:phase5": "node tests/run-phase-5.js",
    "test:phase6": "node tests/run-phase-6.js",
    "test:phase7": "node tests/run-phase-7.js",
    "test:phase8": "node tests/run-phase-8.js"
  },
  "build": {
    "appId": "com.ventasimplehub.app",
    "productName": "Venta Simple",
    "copyright": "Copyright © 2026 Julian Matias Molineris. Todos los derechos reservados.",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "renderer/**/*",
      "public/**/*",
      "package.json"
    ],
    "protocols": [
      {
        "name": "VentaSimple",
        "schemes": [
          "ventasimple"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "molinerisit",
      "repo": "venta-simple-pos",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Julian Matias Molineris",
      "legalTrademarks": "Venta Simple Hub"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Venta Simple",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/icon.ico",
      "menuCategory": "Venta Simple",
      "include": "build/installer.nsh"
    }
  },
  "author": "Julian Matias Molineris",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "sequelize-cli": "^6.6.2"
  },
  "dependencies": {
    "@tillpos/xml-escpos-helper": "^0.3.1",
    "afip-apis": "^0.5.5",
    "axios": "^1.6.5",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "cheerio": "^1.0.0-rc.12",
    "electron-pos-printer": "^1.3.7",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "keytar": "^7.9.0",
    "node-fetch": "^2.7.0",
    "node-thermal-printer": "^4.5.0",
    "nodemailer": "^8.0.5",
    "papaparse": "^5.5.3",
    "sequelize": "^6.35.2",
    "serialport": "^12.0.0",
    "sqlite3": "^5.1.7",
    "systeminformation": "^5.31.5",
    "umzug": "^3.8.2",
    "ws": "^8.20.0"
  },
  "overrides": {
    "undici": "5.28.3"
  }
}
