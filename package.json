{
  "name": "sistema-gestion-desktop",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Escritorio con Node.js y Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "test:phase2": "node tests/run-phase-2.js",
    "test:phase3": "node tests/run-phase-3.js",
    "test:phase4": "node tests/run-phase-4.js"
  },
  "build": {
    "appId": "com.julianmolineris.sistemagestion",
    "productName": "Sistema de Gestión La Macelleria",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "renderer/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": "Julian Molineris",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "sequelize-cli": "^6.6.2"
  },
  "dependencies": {
    "@tillpos/xml-escpos-helper": "^0.3.1",
    "afip-apis": "^0.5.5",
    "axios": "^1.6.5",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0-rc.12",
    "electron-pos-printer": "^1.3.7",
    "jsonwebtoken": "^9.0.2",
    "keytar": "^7.9.0",
    "node-fetch": "^2.7.0",
    "node-thermal-printer": "^4.5.0",
    "papaparse": "^5.5.3",
    "sequelize": "^6.35.2",
    "serialport": "^12.0.0",
    "sqlite3": "^5.1.7",
    "umzug": "^3.8.2"
  },
  "overrides": {
    "undici": "5.28.3"
  }
}